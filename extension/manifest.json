{
  "manifest_version": 3,
  "name": "Daily Primer",
  "version": "1.0.0",
  "description": "Shows your Obsidian daily note on new tabs and enforces delays on distracting sites.",
  "key": "",
  "permissions": [
    "storage",
    "nativeMessaging",
    "webNavigation"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}